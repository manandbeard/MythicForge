rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }

    function isValidId(id) { 
        return id is string && id.size() <= 150 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
        return isSignedIn() && request.auth.token.email == "river.soldier@gmail.com"; 
    }

    function isValidCharacter(data) {
        return data.uid == request.auth.uid 
            && data.name is string && data.name.size() > 0 && data.name.size() <= 200;
    }

    function isValidCampaign(data) {
        return data.uid == request.auth.uid
            && data.name is string && data.name.size() > 0 && data.name.size() <= 200;
    }

    function isValidCampaignNote(data) {
        return data.title is string && data.title.size() > 0 && data.title.size() <= 200
            && data.content is string
            && data.type is string && data.type in ["world", "plot", "location", "session", "general"];
    }

    match /characters/{characterId} {
      allow get: if isSignedIn() && isValidId(characterId) && existing().uid == request.auth.uid;
      allow list: if isSignedIn() && existing().uid == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(characterId)
        && isValidCharacter(incoming())
        && incoming().keys().hasAny(['uid', 'name']);
        
      allow update: if isSignedIn() 
        && isValidId(characterId)
        && existing().uid == request.auth.uid
        && incoming().uid == existing().uid
        && isValidCharacter(incoming());

      allow delete: if isSignedIn() && isValidId(characterId) && existing().uid == request.auth.uid;
    }

    match /library/{dataId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
    }
    
    match /users/{userId} {
        allow get: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
        allow list: if isSignedIn() && request.auth.uid == userId;
        allow write: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
    }

    match /campaigns/{campaignId} {
      allow get: if isSignedIn() && isValidId(campaignId) && existing().uid == request.auth.uid;
      allow list: if isSignedIn() && existing().uid == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(campaignId)
        && isValidCampaign(incoming());
        
      allow update: if isSignedIn()
        && isValidId(campaignId)
        && existing().uid == request.auth.uid
        && incoming().uid == existing().uid
        && isValidCampaign(incoming());
        
      allow delete: if isSignedIn() && isValidId(campaignId) && existing().uid == request.auth.uid;
    }

    match /campaigns/{campaignId}/notes/{noteId} {
      allow get: if isSignedIn() && isValidId(campaignId) && isValidId(noteId);
      allow list: if isSignedIn() && isValidId(campaignId);
      
      allow create: if isSignedIn()
        && isValidId(campaignId) && isValidId(noteId)
        && get(/databases/$(database)/documents/campaigns/$(campaignId)).data.uid == request.auth.uid
        && isValidCampaignNote(incoming());
        
      allow update: if isSignedIn()
        && isValidId(campaignId) && isValidId(noteId)
        && get(/databases/$(database)/documents/campaigns/$(campaignId)).data.uid == request.auth.uid
        && isValidCampaignNote(incoming());
        
      allow delete: if isSignedIn()
        && isValidId(campaignId) && isValidId(noteId)
        && get(/databases/$(database)/documents/campaigns/$(campaignId)).data.uid == request.auth.uid;
    }

    match /campaigns/{campaignId}/rolls/{rollId} {
      allow get: if isSignedIn() && isValidId(campaignId) && isValidId(rollId);
      allow list: if isSignedIn() && isValidId(campaignId);

      allow create: if isSignedIn()
        && isValidId(campaignId) && isValidId(rollId)
        && incoming().playerName is string && incoming().playerName.size() > 0 && incoming().playerName.size() <= 200
        && incoming().timestamp is number
        && incoming().request is map
        && incoming().result is map;
        
      allow update: if false;
      allow delete: if false;
    }
  }
}
